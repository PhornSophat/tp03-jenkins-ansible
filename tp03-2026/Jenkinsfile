pipeline {
    agent { label 'tp03-agent' }

    options {
        timestamps()
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 25, unit: 'MINUTES')
    }

    environment {
        COMPOSER_ALLOW_SUPERUSER = '1'
        APP_ENV = 'testing'
        COMPOSER_CACHE_DIR = "${WORKSPACE}/.composer-cache"
        NPM_CONFIG_CACHE = "${WORKSPACE}/.npm-cache"
    }

    stages {
        stage('Checkout') {
            steps {
                deleteDir()
                checkout scm
            }
        }

        stage('Prepare Environment') {
            steps {
                dir('tp03-2026') {
                    sh 'cp -n .env.example .env || true'
                    sh 'mkdir -p "$COMPOSER_CACHE_DIR" "$NPM_CONFIG_CACHE" storage/test-results'
                    sh 'mkdir -p database && touch database/database.sqlite'
                    sh 'php -v'
                    sh 'composer --version'
                    sh 'node -v'
                    sh 'npm -v'
                }
            }
        }

        stage('Install PHP Dependencies') {
            steps {
                dir('tp03-2026') {
                    sh 'composer install --no-interaction --prefer-dist --optimize-autoloader --no-progress'
                }
            }
        }

        stage('Install JS Dependencies') {
            steps {
                dir('tp03-2026') {
                    sh 'npm ci --prefer-offline --no-audit'
                }
            }
        }

        stage('Generate App Key') {
            steps {
                dir('tp03-2026') {
                    sh 'php artisan key:generate --force'
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('tp03-2026') {
                    sh 'DB_CONNECTION=sqlite DB_DATABASE=$WORKSPACE/tp03-2026/database/database.sqlite php artisan migrate:fresh --force'
                    sh 'DB_CONNECTION=sqlite DB_DATABASE=$WORKSPACE/tp03-2026/database/database.sqlite php artisan test --compact --log-junit storage/test-results/junit.xml'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('tp03-2026') {
                    sh 'npm run build'
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'tp03-2026/storage/logs/*.log', allowEmptyArchive: true
            junit testResults: 'tp03-2026/storage/test-results/junit.xml', allowEmptyResults: true
            sh 'rm -rf tp03-2026/node_modules tp03-2026/vendor || true'
        }
    }
}
